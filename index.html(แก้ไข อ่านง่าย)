<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Drone Racing Grand Championship</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Bai+Jamjuree:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --racing-red: #e11d48;
            --dark-bg: #0f172a;
            --panel-bg: rgba(30, 41, 59, 0.7);
        }
        body { 
            font-family: 'Bai Jamjuree', sans-serif; 
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            color: #f8fafc; 
            height: 100vh; 
            overflow: hidden; 
        }
        .digital-font { font-family: 'Orbitron', sans-serif; }
        
        /* สไตล์ความสวยงามระดับพรีเมียม */
        .glass-panel {
            background: var(--panel-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        }
        
        .timer-glow {
            text-shadow: 0 0 20px rgba(225, 29, 72, 0.5);
            color: #ffffff;
        }

        .btn-racing {
            background: linear-gradient(135deg, #e11d48 0%, #9f1239 100%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-racing:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(225, 29, 72, 0.4);
            filter: brightness(1.1);
        }

        /* ตารางอันดับสไตล์ Championship */
        .rank-row { transition: all 0.2s; border-left: 4px solid transparent; }
        .rank-1 { background: linear-gradient(90deg, rgba(255, 215, 0, 0.1) 0%, transparent 100%); border-left-color: #fbbf24; }
        .rank-2 { background: linear-gradient(90deg, rgba(226, 232, 240, 0.1) 0%, transparent 100%); border-left-color: #94a3b8; }
        .rank-3 { background: linear-gradient(90deg, rgba(251, 146, 60, 0.1) 0%, transparent 100%); border-left-color: #ea580c; }
        
        input::placeholder { color: #475569; }
        .scroll-custom::-webkit-scrollbar { width: 6px; }
        .scroll-custom::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
    </style>
</head>
<body class="p-4">

    <div class="max-w-[1600px] mx-auto h-full flex flex-col gap-4">
        
        <header class="glass-panel rounded-3xl p-4 flex items-center justify-between border-b-4 border-red-600">
            <div class="flex items-center gap-4">
                <div class="bg-red-600 p-2 rounded-lg shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <div>
                    <h1 class="digital-font text-2xl font-black tracking-tighter leading-none italic">DRONE <span class="text-red-600">CHAMPIONSHIP</span></h1>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em]">Official Timing System v6.0</p>
                </div>
            </div>
            
            <div class="flex flex-col items-center">
                <div id="timerDisplay" class="digital-font text-7xl font-black timer-glow leading-none">03:00</div>
                <div class="flex gap-2 mt-2">
                    <button onclick="startTimer()" class="bg-white/10 hover:bg-emerald-600 text-[10px] font-bold px-4 py-1 rounded-full transition-all border border-white/20">START</button>
                    <button onclick="stopTimer()" class="bg-white/10 hover:bg-red-600 text-[10px] font-bold px-4 py-1 rounded-full transition-all border border-white/20">STOP</button>
                    <button onclick="resetTimer()" class="bg-white/10 hover:bg-slate-600 text-[10px] font-bold px-4 py-1 rounded-full transition-all border border-white/20">RESET</button>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div class="text-right hidden md:block">
                    <div class="text-[10px] font-bold text-slate-500 uppercase">System Status</div>
                    <div class="flex items-center gap-2 text-emerald-400 font-bold text-xs uppercase">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        Live Connection
                    </div>
                </div>
            </div>
        </header>

        <main class="grid grid-cols-1 lg:grid-cols-12 gap-4 flex-1 overflow-hidden">
            
            <section class="lg:col-span-4 flex flex-col gap-4">
                <div class="glass-panel p-6 rounded-3xl h-full border-t-4 border-white">
                    <h2 class="text-red-600 font-black text-sm uppercase tracking-widest mb-6 flex items-center gap-2">
                        <span class="w-2 h-4 bg-red-600 block"></span> Input Statistics
                    </h2>
                    
                    <div class="space-y-8">
                        <div>
                            <label class="text-[11px] font-bold text-slate-400 uppercase mb-3 block italic">1. Select Competitor</label>
                            <select id="teamId" onchange="switchTab(this.value)" class="w-full bg-slate-900/80 border-2 border-slate-700 rounded-2xl p-4 text-white font-bold text-xl focus:border-red-600 outline-none transition-all appearance-none cursor-pointer shadow-inner">
                                <option value="">-- ดึงข้อมูลทีม --</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="text-[11px] font-bold text-slate-400 uppercase mb-3 block italic">2. Lap Time Record</label>
                            <div class="grid grid-cols-3 gap-3 bg-black/40 p-4 rounded-2xl border border-slate-700">
                                <div class="text-center">
                                    <span class="text-[9px] font-bold text-slate-500 uppercase">Min</span>
                                    <input type="number" id="inMin" placeholder="0" class="w-full bg-transparent text-center text-5xl font-black digital-font text-white outline-none">
                                </div>
                                <div class="text-center border-x border-slate-800">
                                    <span class="text-[9px] font-bold text-slate-500 uppercase">Sec</span>
                                    <input type="number" id="inSec" placeholder="00" class="w-full bg-transparent text-center text-5xl font-black digital-font text-white outline-none">
                                </div>
                                <div class="text-center">
                                    <span class="text-[9px] font-bold text-slate-500 uppercase">Ms</span>
                                    <input type="number" id="inMs" placeholder="000" class="w-full bg-transparent text-center text-5xl font-black digital-font text-white outline-none">
                                </div>
                            </div>
                        </div>

                        <button onclick="addLap()" id="addBtn" class="btn-racing w-full py-6 rounded-2xl font-black text-2xl shadow-2xl flex items-center justify-center gap-3 active:scale-95">
                            <span>RECORD LAP</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" />
                            </svg>
                        </button>
                    </div>
                </div>
            </section>

            <section class="lg:col-span-8 glass-panel rounded-3xl overflow-hidden flex flex-col border-t-4 border-red-600">
                <div class="bg-slate-900/80 px-8 py-6 flex justify-between items-end border-b border-slate-700">
                    <div>
                        <h2 id="displayTeamName" class="font-black text-5xl text-white italic uppercase leading-none tracking-tighter">- WAITING -</h2>
                        <p id="headerLabel" class="text-red-500 font-bold text-xs uppercase mt-2 tracking-widest">Select Team to View Stats</p>
                    </div>
                    <div id="displayRound" class="digital-font text-lg font-bold bg-white text-black px-6 py-1 rounded-tl-xl rounded-br-xl">
                        ROUND: 0 / 2
                    </div>
                </div>
                
                <div class="flex-1 overflow-y-auto scroll-custom">
                    <table class="w-full">
                        <thead id="tableHead" class="bg-slate-800/50 text-slate-400 text-[11px] font-bold uppercase sticky top-0 backdrop-blur-md">
                            </thead>
                        <tbody id="scoreBody" class="text-lg">
                            </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <script>
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzUUU59y_YpxkR6q1NhWAc14HlNnrmQUCGg6Te_UsP_eAGRlVDYqgk01BjqgmJrxAiA6g/exec';
        
        let timeLeft = 180;
        let timerInterval;
        let allTeamsData = {}; 
        let currentMode = "none";
        let currentActiveId = "";

        window.onload = async () => {
            await syncWithDatabase();
        };

        async function syncWithDatabase() {
            try {
                const response = await fetch(SCRIPT_URL);
                const teams = await response.json(); 
                const select = document.getElementById('teamId');
                const lastSelected = select.value;

                select.innerHTML = '<option value="">-- Competitors --</option>';
                select.innerHTML += '<option value="VIEW_ALL" style="color:#ef4444; font-weight:black;">🚩 LEADERBOARD (LIVE)</option>';
                
                teams.forEach(team => {
                    select.innerHTML += `<option value="${team.id}">${team.name}</option>`;
                    allTeamsData[team.id] = { name: team.name, laps: team.laps || [] };
                });

                if(lastSelected) {
                    select.value = lastSelected;
                    switchTab(lastSelected);
                }
            } catch (e) { 
                alert("Cloud Connection Failed");
            }
        }

        function switchTab(val) {
            if(!val) {
                currentMode = "none";
                document.getElementById('displayTeamName').innerText = "- WAITING -";
                document.getElementById('scoreBody').innerHTML = '<tr><td colspan="3" class="px-8 py-32 text-center text-slate-600 font-bold uppercase tracking-widest opacity-30">No selection</td></tr>';
                return;
            }
            if(val === "VIEW_ALL") { currentMode = "all"; renderLeaderboard(); } 
            else { currentMode = "single"; currentActiveId = val; renderSingleTeam(); }
        }

        function timeToMs(timeStr) {
            const p = timeStr.split(':');
            return (parseInt(p[0]) * 60000) + (parseInt(p[1]) * 1000) + parseInt(p[2]);
        }

        async function addLap() {
            const id = document.getElementById('teamId').value;
            if (!id || id === "VIEW_ALL") return alert("Please select a team!");
            if (allTeamsData[id].laps.length >= 2) return alert("Rounds Limit Reached!");

            // ปรับแต่งการกรอกเวลาให้เป็น 0:00:000 อัตโนมัติ
            const m = document.getElementById('inMin').value || 0;
            const s = document.getElementById('inSec').value || 0;
            const ms = document.getElementById('inMs').value || 0;
            
            const timeStr = `${m}:${s.toString().padStart(2,'0')}:${ms.toString().padStart(3,'0')}`;
            const lapData = { teamId: id, roundNum: allTeamsData[id].laps.length + 1, timeStr };

            try {
                const btn = document.getElementById('addBtn');
                btn.innerHTML = '<span class="animate-pulse">TRANSMITTING...</span>';
                btn.disabled = true;

                await fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(lapData) });
                
                allTeamsData[id].laps.push({ roundNum: lapData.roundNum, timeStr: lapData.timeStr });
                if(currentMode === "all") renderLeaderboard(); else renderSingleTeam();
                
                document.getElementById('inMin').value = ''; 
                document.getElementById('inSec').value = ''; 
                document.getElementById('inMs').value = '';
                btn.innerHTML = '<span>RECORD LAP</span>';
                btn.disabled = false;
            } catch (e) { alert("Network Error"); }
        }

        function renderSingleTeam() {
            const team = allTeamsData[currentActiveId];
            const tbody = document.getElementById('scoreBody');
            document.getElementById('headerLabel').innerText = "Detailed Performance Analysis";
            document.getElementById('displayTeamName').innerText = team.name;
            document.getElementById('displayRound').innerText = `ROUND: ${team.laps.length} / 2`;
            document.getElementById('tableHead').innerHTML = `<tr><th class="px-8 py-4">#</th><th class="px-8 py-4">Lap Attempt</th><th class="px-8 py-4 text-right">Time Record</th></tr>`;
            
            tbody.innerHTML = team.laps.length === 0 ? '<tr><td colspan="3" class="px-8 py-20 text-center text-slate-600">No records found.</td></tr>' : "";
            team.laps.forEach(lap => {
                tbody.innerHTML += `
                    <tr class="border-b border-white/5 bg-white/5">
                        <td class="px-8 py-6 text-red-500 font-bold">-</td>
                        <td class="px-8 py-6 font-bold uppercase tracking-widest text-slate-300">Round ${lap.roundNum}</td>
                        <td class="px-8 py-6 digital-font text-4xl text-white text-right font-black">${lap.timeStr}</td>
                    </tr>`;
            });
        }

        function renderLeaderboard() {
            const tbody = document.getElementById('scoreBody');
            document.getElementById('headerLabel').innerText = "Live Tournament Standing";
            document.getElementById('displayTeamName').innerText = "LEADERBOARD";
            document.getElementById('displayRound').innerText = "OVERALL";
            document.getElementById('tableHead').innerHTML = `<tr><th class="px-8 py-4">Position</th><th class="px-8 py-4">Team Name</th><th class="px-8 py-4 text-right">Personal Best</th></tr>`;
            
            let list = [];
            for (let id in allTeamsData) {
                if (allTeamsData[id].laps.length > 0) {
                    let best = allTeamsData[id].laps.reduce((m, l) => timeToMs(l.timeStr) < timeToMs(m.timeStr) ? l : m);
                    list.push({ name: allTeamsData[id].name, bestTime: best.timeStr, ms: timeToMs(best.timeStr) });
                }
            }
            list.sort((a, b) => a.ms - b.ms);
            tbody.innerHTML = list.length === 0 ? '<tr><td colspan="3" class="px-8 py-20 text-center text-slate-600 italic">Waiting for results...</td></tr>' : "";
            
            list.forEach((item, index) => {
                let rankClass = index === 0 ? "rank-1" : index === 1 ? "rank-2" : index === 2 ? "rank-3" : "";
                let rankText = index === 0 ? "text-amber-400" : index === 1 ? "text-slate-300" : index === 2 ? "text-orange-500" : "text-slate-500";
                
                tbody.innerHTML += `
                    <tr class="rank-row ${rankClass} border-b border-white/5">
                        <td class="px-8 py-6 digital-font text-3xl font-black ${rankText}">P${(index + 1).toString().padStart(2, '0')}</td>
                        <td class="px-8 py-6 font-black text-white text-xl italic uppercase">${item.name}</td>
                        <td class="px-8 py-6 digital-font text-4xl text-white text-right font-black">${item.bestTime}</td>
                    </tr>`;
            });
        }

        // Timer
        function updateTimerDisplay() {
            const m = Math.floor(timeLeft / 60); const s = timeLeft % 60;
            document.getElementById('timerDisplay').innerText = `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }
        function startTimer() { if(!timerInterval) timerInterval = setInterval(() => { if(timeLeft > 0){ timeLeft--; updateTimerDisplay(); } else stopTimer(); }, 1000); }
        function stopTimer() { clearInterval(timerInterval); timerInterval = null; }
        function resetTimer() { stopTimer(); timeLeft = 180; updateTimerDisplay(); }
    </script>
</body>
</html>
