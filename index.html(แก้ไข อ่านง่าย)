<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Drone Racing Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Kanit:wght@300;500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Kanit', sans-serif; background-color: #0f172a; color: #f1f5f9; height: 100vh; overflow: hidden; }
        .digital-font { font-family: 'Orbitron', sans-serif; }
        .best-lap-row { background: linear-gradient(90deg, #064e3b 0%, #0f172a 100%); border-left: 4px solid #10b981; }
        .active-tab { background-color: #2563eb !important; color: white !important; border-color: #60a5fa !important; box-shadow: 0 0 15px rgba(37, 99, 235, 0.4); }
        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .scroll-custom::-webkit-scrollbar { width: 6px; }
        .scroll-custom::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
    </style>
</head>
<body class="p-2 md:p-4">

    <div class="max-w-6xl mx-auto h-full flex flex-col gap-4">
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center bg-slate-800 p-4 rounded-2xl border border-slate-700 shadow-xl">
            <div class="text-center md:text-left">
                <h1 class="text-blue-400 font-black tracking-widest text-xl uppercase digital-font">DRONE-RACING</h1>
                <p class="text-slate-500 text-xs">OFFICIAL SCOREBOARD v3.0</p>
            </div>
            
            <div class="text-center">
                <div id="timerDisplay" class="digital-font text-6xl font-black text-white drop-shadow-[0_0_10px_rgba(255,255,255,0.2)]">03:00</div>
                <div class="flex justify-center gap-2 mt-2">
                    <button onclick="startTimer()" class="bg-emerald-600 hover:bg-emerald-500 text-[10px] px-4 py-1 rounded-full font-bold transition-all">START</button>
                    <button onclick="stopTimer()" class="bg-amber-600 hover:bg-amber-500 text-[10px] px-4 py-1 rounded-full font-bold transition-all">PAUSE</button>
                    <button onclick="resetTimer()" class="bg-slate-600 hover:bg-slate-500 text-[10px] px-4 py-1 rounded-full font-bold transition-all">RESET</button>
                </div>
            </div>

            <div class="hidden md:block text-right text-slate-400 text-xs uppercase font-bold">
                Live Data Connected
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 flex-1 overflow-hidden">
            
            <div class="lg:col-span-4 flex flex-col gap-4 h-full">
                <div class="bg-slate-800 p-6 rounded-3xl border border-slate-700 shadow-xl">
                    <h2 class="text-slate-400 text-xs font-bold mb-4 uppercase tracking-tighter">1. Input Statistics</h2>
                    <div class="space-y-4">
                        <div>
                            <select id="teamId" onchange="switchTab(this.value)" class="w-full bg-slate-900 border border-slate-600 rounded-xl p-4 text-white focus:ring-2 focus:ring-blue-500 outline-none">
                                <option value="">-- เลือกทีมแข่ง --</option>
                            </select>
                        </div>
                        <div class="flex items-center gap-2 bg-slate-900 p-3 rounded-xl border border-slate-600">
                            <input type="number" id="inMin" placeholder="0" class="w-full bg-transparent text-center text-2xl font-bold outline-none">
                            <span class="text-slate-600">:</span>
                            <input type="number" id="inSec" placeholder="00" class="w-full bg-transparent text-center text-2xl font-bold outline-none" max="59">
                            <span class="text-slate-600">:</span>
                            <input type="number" id="inMs" placeholder="000" class="w-full bg-transparent text-center text-2xl font-bold outline-none" max="999">
                        </div>
                        <button onclick="addLap()" id="addBtn" class="w-full bg-blue-600 hover:bg-blue-500 py-4 rounded-2xl font-black text-lg transition-all shadow-lg active:scale-95">
                            SAVE RECORD
                        </button>
                    </div>
                </div>

                <div class="bg-slate-800 p-4 rounded-3xl border border-slate-700 flex-1 overflow-hidden flex flex-col">
                    <h2 class="text-slate-400 text-[10px] font-bold mb-3 uppercase tracking-tighter">Team Switcher</h2>
                    <div id="teamTabs" class="flex flex-wrap gap-2 overflow-y-auto scroll-custom p-1">
                        </div>
                </div>
            </div>

            <div class="lg:col-span-8 bg-slate-800 rounded-3xl border border-slate-700 shadow-xl overflow-hidden flex flex-col h-full">
                <div id="activeTeamHeader" class="bg-slate-700/50 px-6 py-4 flex justify-between items-center border-b border-slate-600">
                    <h2 id="displayTeamName" class="font-bold text-2xl text-blue-400 uppercase tracking-widest">- NO TEAM SELECTED -</h2>
                    <div id="displayRound" class="text-xs font-bold bg-blue-900/50 text-blue-300 px-4 py-1 rounded-full border border-blue-700 uppercase">
                        Rounds: 0 / 5
                    </div>
                </div>
                
                <div class="flex-1 overflow-y-auto scroll-custom">
                    <table class="w-full text-left">
                        <thead class="bg-slate-900/50 text-slate-500 text-[10px] uppercase sticky top-0">
                            <tr>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Lap Order</th>
                                <th class="px-6 py-4 text-right">Time (M:S:MS)</th>
                            </tr>
                        </thead>
                        <tbody id="scoreBody" class="divide-y divide-slate-700/50">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwcoQx7DCcZC0V82i6l57fuAA0zeUdBTZEtf5Tv9D-6J50m6s0CtuxElzj0C5sM8t0nwg/exec';
        let timeLeft = 180;
        let timerInterval;
        let allTeamsData = {};
        let currentActiveTeam = "";

        window.onload = async () => {
            try {
                const response = await fetch(SCRIPT_URL);
                const teams = await response.json();
                const select = document.getElementById('teamId');
                const tabsContainer = document.getElementById('teamTabs');
                
                teams.forEach(team => {
                    if(team && team !== "Timestamp") {
                        // เพิ่มใน Select
                        select.innerHTML += `<option value="${team}">${team}</option>`;
                        // สร้างปุ่ม Tab
                        const btn = document.createElement('button');
                        btn.id = `tab-${team}`;
                        btn.className = "bg-slate-900 text-slate-400 border border-slate-700 px-4 py-2 rounded-xl text-xs font-bold transition-all hover:border-blue-500";
                        btn.innerText = team;
                        btn.onclick = () => switchTab(team);
                        tabsContainer.appendChild(btn);
                        
                        allTeamsData[team] = [];
                    }
                });
            } catch (e) { console.error(e); }
        };

        function switchTab(teamName) {
            if(!teamName) return;
            currentActiveTeam = teamName;
            document.getElementById('teamId').value = teamName;
            
            // ปรับสีปุ่ม Tab
            document.querySelectorAll('#teamTabs button').forEach(btn => btn.classList.remove('active-tab'));
            const activeBtn = document.getElementById(`tab-${teamName}`);
            if(activeBtn) activeBtn.classList.add('active-tab');
            
            renderActiveScoreboard();
        }

        async function addLap() {
            const teamId = document.getElementById('teamId').value;
            const m = document.getElementById('inMin').value || 0;
            const s = document.getElementById('inSec').value || 0;
            const ms = document.getElementById('inMs').value || 0;

            if (!teamId) return alert("กรุณาเลือกทีม!");
            if (allTeamsData[teamId].length >= 5) return alert("ครบ 5 รอบแล้ว!");

            const totalMs = (parseInt(m) * 60000) + (parseInt(s) * 1000) + parseInt(ms);
            const timeStr = `${m}:${s.toString().padStart(2,'0')}:${ms.toString().padStart(3,'0')}`;
            const lapData = { teamId, roundNum: allTeamsData[teamId].length + 1, timeStr, totalMs };

            try {
                document.getElementById('addBtn').innerText = "SAVING...";
                document.getElementById('addBtn').disabled = true;

                await fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(lapData) });
                
                allTeamsData[teamId].push(lapData);
                switchTab(teamId); // อัปเดตหน้าจอไปที่ทีมนั้นทันที
                
                document.getElementById('inMin').value = ''; 
                document.getElementById('inSec').value = ''; 
                document.getElementById('inMs').value = '';
                document.getElementById('addBtn').innerText = "SAVE RECORD";
                document.getElementById('addBtn').disabled = false;

                if (allTeamsData[teamId].length === 5) {
                    setTimeout(() => alert(`ทีม ${teamId} ครบ 5 รอบแล้ว!`), 200);
                    document.getElementById(`tab-${teamId}`).innerHTML += " ✅";
                }
            } catch (e) { alert("Error!"); document.getElementById('addBtn').disabled = false; }
        }

        function renderActiveScoreboard() {
            if(!currentActiveTeam) return;
            
            const teamLaps = allTeamsData[currentActiveTeam];
            const tbody = document.getElementById('scoreBody');
            const displayTeamName = document.getElementById('displayTeamName');
            const displayRound = document.getElementById('displayRound');

            displayTeamName.innerText = currentActiveTeam;
            displayRound.innerText = `Rounds: ${teamLaps.length} / 5`;
            
            if(teamLaps.length === 5) displayRound.classList.replace('bg-blue-900/50', 'bg-emerald-900/50');
            else displayRound.classList.replace('bg-emerald-900/50', 'bg-blue-900/50');

            // เรียงลำดับ Best Lap
            const minTime = teamLaps.length > 0 ? Math.min(...teamLaps.map(l => l.totalMs)) : null;
            let sortedLaps = [...teamLaps].sort((a,b) => a.totalMs - b.totalMs);

            tbody.innerHTML = "";
            sortedLaps.forEach(lap => {
                const isBest = lap.totalMs === minTime;
                tbody.innerHTML += `
                    <tr class="transition-all ${isBest ? 'best-lap-row' : ''}">
                        <td class="px-6 py-4">${isBest ? '<span class="text-emerald-400 font-bold text-xs">★ BEST</span>' : '-'}</td>
                        <td class="px-6 py-4 font-bold text-slate-400">Round ${lap.roundNum}</td>
                        <td class="px-6 py-4 digital-font text-3xl text-blue-400 text-right">${lap.timeStr}</td>
                    </tr>
                `;
            });
        }

        // Timer functions
        function updateTimerDisplay() {
            const m = Math.floor(timeLeft / 60);
            const s = timeLeft % 60;
            document.getElementById('timerDisplay').innerText = `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }
        function startTimer() { if(!timerInterval) timerInterval = setInterval(() => { if(timeLeft > 0){ timeLeft--; updateTimerDisplay(); } else stopTimer(); }, 1000); }
        function stopTimer() { clearInterval(timerInterval); timerInterval = null; }
        function resetTimer() { stopTimer(); timeLeft = 180; updateTimerDisplay(); }
    </script>
</body>
</html>
